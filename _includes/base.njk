<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="theme-color" content="#012a4a">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <meta name="author" content="Papá de Martina">
  <meta name="robots" content="index, follow">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  <meta property="og:image" content="{{ ogImage }}">
  {% if twitterCard %}<meta name="twitter:card" content="{{ twitterCard }}">{% endif %}
  {% if twitterTitle %}<meta name="twitter:title" content="{{ twitterTitle }}">{% endif %}
  {% if twitterDescription %}<meta name="twitter:description" content="{{ twitterDescription }}">{% endif %}
  {% if twitterImage %}<meta name="twitter:image" content="{{ twitterImage }}">{% endif %}
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/style.css">
  {% for css in extraCss %}<link rel="stylesheet" href="{{ css }}">
  {% endfor %}
  <link rel="icon" type="image/png" href="/assets/img/martina_profile_1778904530237.png">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8VT55Y2PFC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-8VT55Y2PFC');
  </script>
  {% block extraHead %}{% endblock %}
</head>
<body>

<header class="site-header-compact">
  <div class="header-content-compact">
    <div class="site-title-compact">
      <span class="header-piece-compact">♕</span> <a href="/">Martina</a>
    </div>
    <button class="hamburger-btn" id="hamburger-btn" aria-label="Menú">☰</button>
    <nav class="nav-bar-compact">
      <a href="/" class="nav-link{% if activeNav == 'inicio' %} active{% endif %}">Inicio</a>
      <a href="/#cuentos" class="nav-link{% if activeNav == 'cuentos' %} active{% endif %}">Cuentos</a>
      <a href="/juegos.html" class="nav-link{% if activeNav == 'juegos' %} active{% endif %}">Juegos</a>
      <a href="/album.html" class="nav-link{% if activeNav == 'album' %} active{% endif %}">Álbum</a>
      <a href="/acerca-de.html" class="nav-link{% if activeNav == 'acerca-de' %} active{% endif %}">Acerca de</a>
      <a href="/galeria.html" class="nav-link{% if activeNav == 'galeria' %} active{% endif %}">Galería</a>
      <a href="/difundir.html" class="nav-link{% if activeNav == 'difundir' %} active{% endif %}">Difundir</a>
    </nav>
  </div>
</header>

<main>
{{ content | safe }}
</main>

{% block afterMain %}{% endblock %}

<footer class="site-footer">
  <a href="https://github.com/raestrada/martina" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub">
    <svg viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    Ver en GitHub
  </a>
  <p>{{ footerText or 'Historias originales para Martina, por papá.' }}<br>{{ footerQuote or '«El ajedrez es un cuento de hadas de la mente» — Mikhail Tal' }}</p>
  <p style="font-size: 0.8rem; margin-top: 1rem; color: var(--board-dark); line-height: 1.4;">
    Esta obra (cuentos e ilustraciones) está bajo una <a href="https://creativecommons.org/licenses/by-nc/4.0/deed.es" target="_blank" rel="license noopener noreferrer" style="color: inherit; text-decoration: underline;">Licencia Creative Commons Atribución-NoComercial 4.0 Internacional</a>.<br>
    El código de la web es de código abierto (MIT). <strong>Prohibida la monetización o uso comercial del contenido sin permiso explícito del autor.</strong>
  </p>
</footer>

{% for js in extraJs %}<script src="{{ js }}"></script>
{% endfor %}
<script src="/js/main.js"></script>
{% block extraBodyEnd %}{% endblock %}
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="theme-color" content="#012a4a" id="theme-color-meta">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <meta name="author" content="Papá de Martina">
  <meta name="robots" content="index, follow">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}">
  <meta name="twitter:title" content="{{ twitterTitle or ogTitle or title }}">
  <meta name="twitter:description" content="{{ twitterDescription or ogDescription or description }}">
  <meta name="twitter:image" content="{{ twitterImage or ogImage }}">
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/style.css">
  {% for css in extraCss %}<link rel="stylesheet" href="{{ css }}">
  {% endfor %}
  <link rel="icon" type="image/png" href="/assets/img/martina_profile_1778904530237.png">
  {% if ogType == 'article' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ ogTitle or title }}",
    "description": "{{ ogDescription or description }}",
    "image": "https://martinachess.com{{ ogImage }}",
    "author": { "@type": "Person", "name": "Papá de Martina" },
    "datePublished": "{{ page.date.toISOString() }}",
    "dateModified": "{{ page.date.toISOString() }}"
  }
  </script>
  {% endif %}
  {% block structuredData %}{% endblock %}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8VT55Y2PFC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-8VT55Y2PFC');
  </script>
  {% block extraHead %}{% endblock %}
</head>
<body>

<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

<header class="site-header-compact">
  <div class="header-content-compact">
    <div class="site-title-compact">
      <span class="header-piece-compact">♕</span> <a href="/">Martina</a>
    </div>
    <nav class="nav-bar-compact" id="nav-bar">
      <a href="/" class="nav-link{% if activeNav == 'inicio' %} active{% endif %}">Inicio</a>
      <a href="/#cuentos" class="nav-link{% if activeNav == 'cuentos' %} active{% endif %}">Cuentos</a>
      <a href="/juegos.html" class="nav-link{% if activeNav == 'juegos' %} active{% endif %}">Juegos</a>
      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger{% if activeNav in ['album', 'galeria', 'acerca-de', 'difundir'] %} active{% endif %}" id="nav-more-btn" aria-expanded="false" aria-haspopup="true">Más ▾</button>
        <div class="nav-dropdown-menu" id="nav-more-menu">
          <a href="/album.html" class="nav-link{% if activeNav == 'album' %} active{% endif %}">Álbum</a>
          <a href="/galeria.html" class="nav-link{% if activeNav == 'galeria' %} active{% endif %}">Galería</a>
          <a href="/acerca-de.html" class="nav-link{% if activeNav == 'acerca-de' %} active{% endif %}">Acerca de</a>
          <a href="/difundir.html" class="nav-link{% if activeNav == 'difundir' %} active{% endif %}">Difundir</a>
        </div>
      </div>
    </nav>
    <div style="display:flex;align-items:center;gap:0.5rem;">
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar modo oscuro" title="Modo noche">🌙</button>
      <button class="hamburger-btn" id="hamburger-btn" aria-label="Menú">☰</button>
    </div>
  </div>
</header>

<main>
{{ content | safe }}
</main>

{% block afterMain %}{% endblock %}

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-col">
      <h4>Cuentos populares</h4>
      <a href="/cuentos/01-el-primer-movimiento.html">El Primer Movimiento</a>
      <a href="/cuentos/03-la-clavada-del-alfil-exiliado.html">La Clavada del Alfil Exiliado</a>
      <a href="/cuentos/09-la-sombra-que-jugaba.html">La Sombra que Jugaba</a>
      <a href="/cuentos/07-el-pescador-y-el-elegante.html">El Pescador y el Elegante</a>
    </div>
    <div class="footer-col">
      <h4>Juegos</h4>
      <a href="/juegos.html">El Tablero de Juegos</a>
      <a href="/album.html">Álbum de Clavadas</a>
      <a href="/difundir.html">Compartir</a>
      <a href="/rss.xml">Feed RSS</a>
    </div>
    <div class="footer-col">
      <h4>Comunidad</h4>
      <a href="https://github.com/raestrada/martina" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/acerca-de.html">Acerca de</a>
      <a href="https://creativecommons.org/licenses/by-nc/4.0/deed.es" target="_blank" rel="license noopener noreferrer">CC BY-NC 4.0</a>
    </div>
  </div>
  <p class="footer-quote" id="footer-quote">{{ footerQuote or '«El ajedrez es un cuento de hadas de la mente» — Mikhail Tal' }}</p>
  <p style="font-size: 0.8rem; margin-top: 1rem; color: var(--board-dark); line-height: 1.4;">
    Esta obra (cuentos e ilustraciones) está bajo una <a href="https://creativecommons.org/licenses/by-nc/4.0/deed.es" target="_blank" rel="license noopener noreferrer" style="color: inherit; text-decoration: underline;">Licencia Creative Commons Atribución-NoComercial 4.0 Internacional</a>.<br>
    El código de la web es de código abierto (MIT). <strong>Prohibida la monetización o uso comercial del contenido sin permiso explícito del autor.</strong>
  </p>
</footer>

{% for js in extraJs %}<script src="{{ js }}"></script>
{% endfor %}
<script src="/js/main.js"></script>
{% block extraBodyEnd %}{% endblock %}
</body>
</html>

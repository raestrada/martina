    <!-- ⭐ JUEGO DESTACADO: Super Martina -->
    <div class="story-card game-card game-card-featured" data-game="mario">
      <div class="story-thumbnail">
        <img src="/assets/img/super_martina_juego_1780024581060.png" alt="Super Martina: El Salto Mágico">
        <span class="featured-ribbon">⭐ DESTACADO</span>
      </div>
      <div class="story-card-content">
